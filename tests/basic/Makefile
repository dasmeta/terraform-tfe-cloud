run-via-docker:
	docker run -it \
		-v $(pwd):/build \
		-e GIT_TOKEN="ghp_************" \
		-e TERRAFORM_CLOUD_TOKEN="*****************.*******.*******************************************************************" \
		-e AWS_ACCESS_KEY_ID="***************" \
		-e AWS_SECRET_ACCESS_KEY="***************" \
		-e AWS_DEFAULT_REGION="***************" \
		dasmeta/meta create

export TF_VAR_git_token=ghp_************
export TF_VAR_tfc_token=*****************.*******.*******************************************************************
export TFE_TOKEN=*****************.*******.*******************************************************************
export TF_TOKEN_app_terraform_io=*****************.*******.*******************************************************************
